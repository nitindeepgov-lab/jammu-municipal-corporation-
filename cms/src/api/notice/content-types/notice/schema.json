{
  "kind": "collectionType",
  "collectionName": "notices",
  "info": {
    "singularName": "notice",
    "pluralName": "notices",
    "displayName": "📢 Public Notice",
    "description": "Official public and council notices published by JMC. Visible on the Notices page."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "notice_type": {
      "type": "enumeration",
      "enum": ["public", "council"],
      "required": true,
      "default": "public"
    },
    "notice_date": {
      "type": "date",
      "required": true
    },
    "link": {
      "type": "string",
      "required": false
    },
    "description": {
      "type": "text",
      "required": false
    },
    "document": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["files", "images"]
    }
  }
}
