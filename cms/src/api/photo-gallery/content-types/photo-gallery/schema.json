{
  "kind": "collectionType",
  "collectionName": "photo_galleries",
  "info": {
    "singularName": "photo-gallery",
    "pluralName": "photo-galleries",
    "displayName": "Photo Gallery",
    "description": "Images used in the public photo gallery page."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": false
    },
    "caption": {
      "type": "text",
      "required": false
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  }
}
